# Fichier d'exemple pour les variables d'environnement
# Copiez ce fichier en '.env' et modifiez les valeurs si besoin.

# URI de connexion au serveur MLflow local (sqlite par defaut pour du local)
MLFLOW_TRACKING_URI=sqlite:///mlruns.db

# Configuration de l'API
API_HOST=0.0.0.0
API_PORT=8000

# URL de l'API pour le frontend Streamlit
API_URL=http://127.0.0.1:8000
